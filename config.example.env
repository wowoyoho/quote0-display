# ── Quote/0 device ────────────────────────────────────────────────────────────
export QUOTE0_API_KEY="dot_app_xxx"
export QUOTE0_DEVICE_ID="YOUR_DEVICE_ID"

# Optional: task slot keys (only needed if you have multiple content cards)
export QUOTE0_IMAGE_TASK_KEY=""
export QUOTE0_TEXT_TASK_KEY=""

# Refresh display immediately after push (true for manual runs, false for scheduled)
export QUOTE0_REFRESH_NOW="false"

# ── Claude Code ───────────────────────────────────────────────────────────────
# These limits count REAL tokens only (input + output).
# Cache tokens (cache_read / cache_creation) are excluded — they don't count toward limits.
#
# To calibrate CLAUDE_5H_TOKEN_MAX:
#   1. Use Claude Code until you see "usage limit reached, resets at HH:MM"
#   2. Run: python3 display.py --debug-json | grep real_5h
#   3. Set CLAUDE_5H_TOKEN_MAX to that real_5h value
#
# Default 500K is a reasonable starting point for Claude Max.
export CLAUDE_5H_TOKEN_MAX="500000"
export CLAUDE_WEEK_TOKEN_MAX="2000000"

# ── Codex (optional) ──────────────────────────────────────────────────────────
# Reads ~/.codex/auth.json automatically after running `codex` CLI.
# Override token here if needed:
# export CODEX_ACCESS_TOKEN=""
# export CODEX_ACCOUNT_ID=""

# ── DeepSeek (optional) ───────────────────────────────────────────────────────
# Only the Claude Code section is shown if neither Codex nor DeepSeek is configured.
# export DEEPSEEK_API_KEY="sk-xxx"

# ── Preview output ────────────────────────────────────────────────────────────
export QUOTE0_PREVIEW_PATH="/tmp/quote_preview.png"
